extends layout

block headContent
	title User Settings

block content
	+pageTitle("User Settings")

	+contentSection("Display Options")
		.row.pb-3.border-bottom.mb-4
			.col.text-start
				h6 Hide info notes
				span.text-muted Enabling this option hides all informational notes across the site.
			.col.text-end.me-3
				.d-inline-block.text-center
					if (userSettings.hideInfoNotes && userSettings.hideInfoNotes == "true")
						div Yes
						a(href=`./changeSetting?name=hideInfoNotes&value=false`)
							i.bi-toggle2-on.fs-3

					else
						div No
						a(href=`./changeSetting?name=hideInfoNotes&value=true`)
							i.bi-toggle2-off.fs-3


		.row
			.col.text-start
				h6 Manual UTC Offset
					span.small.text-muted.ms-1 (hours)
				span.text-muted If you want to set a custom UTC offset, rather than using your browser's default, you can set it here. This is helpful if your browser uses UTC time as a privacy-protecting measure. For locales ~West of UTC (i.e. West of London), set a negative value; for locales ~East of UTC, set a positive value.
			.col.text-end.me-3
				.d-inline-block.text-end
					form(method="get", action="./changeSetting")
						input(type="hidden", name="name", value="userTzOffset")
						input.form-control(type="text", name="value", value=userTzOffset)

					span.small.text-muted (Example: for New York, enter "-5")

		.row.pb-3.border-bottom.mb-4
			.col.text-start
				h6 <br />Alias Badge Color
				span.text-muted Select the background color for user-defined address aliases.
			.col.text-end.me-3
				.d-inline-block
					- var colors = ["primary", "secondary", "success", "danger", "warning", "info", "light", "dark"];
					each color in colors
						a.badge.me-1(href=`./changeSetting?name=aliasBadgeColor&value=${color}`, class=`bg-${color}`, title=color, data-bs-toggle="tooltip", style="width: 24px; height: 24px; border: 2px solid #fff; display: inline-block; vertical-align: middle;") &nbsp;
					
					if (userSettings.aliasBadgeColor)
						.mt-2
							span.small.text-muted Current: 
							- var textClass = (userSettings.aliasBadgeColor == "light" || userSettings.aliasBadgeColor == "warning") ? "text-dark" : "";
							span.badge(class=`bg-${userSettings.aliasBadgeColor} ${textClass}`) #{userSettings.aliasBadgeColor}

	+contentSection("Address Aliases")
		p.text-muted You can add custom aliases for any address. These aliases will be used throughout the site and take precedence over default miner/pool names.
		
		if (userSettings.addressAliases && Object.keys(userSettings.addressAliases).length > 0)
			.table-responsive
				table.table.table-striped
					thead
						tr
							th Address
							th Alias
							th.text-end Actions
					tbody
						each alias, address in userSettings.addressAliases
							tr
								td.font-monospace #{address}
								td #{alias}
								td.text-end
									a.btn.btn-outline-primary.btn-sm.me-1(href="javascript:void(0)", onclick=`editAlias('${address}', '${alias}')`, title="Edit")
										i.bi-pencil
									a.btn.btn-outline-danger.btn-sm(href=`./changeSetting?name=addressAliases&action=delete&key=${address}`, title="Delete")
										i.bi-trash
		else
			p.text-muted No aliases defined.

		hr

		h6(id="alias-form-title") Add New Alias
		form(id="alias-form", method="get", action="./changeSetting")
			input(type="hidden", name="name", value="addressAliases")
			input(id="alias-action", type="hidden", name="action", value="add")
			.row.g-3
				.col-md-6
					input.form-control(id="alias-address", type="text", name="key", placeholder="Address (e.g. pocx1q...)", required)
				.col-md-4
					input.form-control(id="alias-name", type="text", name="value", placeholder="Alias (e.g. My Cold Wallet)", required)
				.col-md-2
					button.btn.btn-primary.w-100(id="alias-submit-btn", type="submit") Add

	+contentSection("User Settings JSON")
		form(method="post", action="./updateUserSettings")
			input(type="hidden", name="_csrf", value=csrfToken)
			textarea#user-settings-json.form-control.font-monospace.mb-3(name="userSettingsJson", rows=15, readonly) #{JSON.stringify(userSettings, null, 4)}
			
			.row
				.col
					button#save-settings-btn.btn.btn-primary.d-none(type="submit")
						i.bi-save.me-2
						| Save Settings
					
					button#enable-edit-btn.btn.btn-outline-primary(type="button", onclick="enableJsonEdit()")
						i.bi-pencil.me-2
						| Edit JSON
					
					a.btn.btn-outline-primary.ms-2(href="javascript:void(0)", onclick="exportUserSettings()")
						i.bi-download.me-2
						| Export
						
					label.btn.btn-outline-primary.ms-2.mb-0(for="import-file")
						i.bi-upload.me-2
						| Import
						input#import-file(type="file", style="display: none;", onchange="importUserSettings(this)")
				
				.col.text-end
					a.btn.btn-danger(href="./admin/resetUserSettings", onclick="return confirm('Are you sure you want to reset all settings to defaults?')")
						i.bi-arrow-counterclockwise.me-2
						| Reset to Defaults

block endOfBody
	script.
		function editAlias(address, alias) {
			$("#alias-address").val(address);
			$("#alias-name").val(alias);
			$("#alias-form-title").text("Edit Alias");
			$("#alias-submit-btn").text("Update");
			
			window.scrollTo(0, $("#alias-form").offset().top - 100);
			$("#alias-name").focus();
		}

		function enableJsonEdit() {
			$("#user-settings-json").removeAttr("readonly");
			$("#save-settings-btn").removeClass("d-none");
			$("#enable-edit-btn").addClass("d-none");
			$("#user-settings-json").focus();
		}

		function exportUserSettings() {
			var settings = $("textarea[name='userSettingsJson']").val();
			var blob = new Blob([settings], {type: "application/json"});
			var url = URL.createObjectURL(blob);
			var a = document.createElement("a");
			a.href = url;
			a.download = "btcx-user-settings.json";
			document.body.appendChild(a);
			a.click();
			document.body.removeChild(a);
			URL.revokeObjectURL(url);
		}

		function importUserSettings(input) {
			if (input.files && input.files[0]) {
				var reader = new FileReader();
				reader.onload = function(e) {
					try {
						var json = JSON.parse(e.target.result);
						$("textarea[name='userSettingsJson']").val(JSON.stringify(json, null, 4));
						
						enableJsonEdit();
						
						alert("Settings imported into text area. Review and click 'Save Settings' to apply.");
					} catch (err) {
						alert("Error parsing JSON: " + err.message);
					}
				};
				reader.readAsText(input.files[0]);
			}
		}
